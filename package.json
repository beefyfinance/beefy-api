{
  "name": "beefy-api",
  "version": "1.0.0",
  "repository": "beefyfinance/beefy-api",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "install-all": "yarn install --frozen-lockfile && cd packages/address-book && npm ci",
    "start": "node --env-file-if-exists=.env --import tsx src/app.ts",
    "starttvl": "node --heap-prof --import tsx src/api/stats/getTvl.js",
    "heaptvl": "node --heap-prof --import tsx src/api/stats/getTvl.js",
    "dev": "node --watch --env-file-if-exists=.env --import tsx src/app.ts",
    "test:ts": "tsc --project tsconfig.json",
    "format:check": "biome format",
    "format:fix": "biome format --fix",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "lint:fix:unsafe": "biome check --fix --unsafe",
    "prepare": "husky",
    "add:chain": "node --env-file-if-exists=.env --import tsx scripts/add-chain.ts",
    "add:chain:addressbook": "cd packages/address-book && yarn addChain",
    "addClm": "tsx scripts/add-clm.ts",
    "checkClms": "tsx scripts/check-clms.ts",
    "addFarm": "tsx scripts/add-farm.ts",
    "addSushi": "tsx scripts/add-sushi.ts",
    "addSolidly": "tsx scripts/add-solidly.ts",
    "addBalancer": "tsx scripts/add-balancer.ts --network gnosis --project aura-gnosis --poolId",
    "check-oracles": "tsx scripts/check-oracles.ts",
    "mainnet:sushi:add": "tsx scripts/add-farm.ts --network ethereum --project sushi --newFee true --pool",
    "mainnet:verse:add": "tsx scripts/add-quick.ts --network ethereum --project verse --pool",
    "arbitrum:solidlizard:add": "tsx scripts/add-solidly.ts --network arbitrum --project solidlizard --newFee true --lp",
    "base:bvm:add": "tsx scripts/add-solidly.ts --network base --project bvm --newFee true --lp",
    "base:aerodrome:add": "tsx scripts/add-solidly.ts --network base --project aerodrome --newFee true --lp",
    "base:equalizer:add": "tsx scripts/add-solidly.ts --network base --project equalizerBase --newFee true --lp",
    "base:baseSwap:add": "tsx scripts/add-farm.ts --network base --project baseSwap --newFee true",
    "base:sushi:gamma:add": "tsx scripts/add-gamma.ts --network base --project sushiBase --wide true --lp",
    "bsc:pancake:add": "tsx scripts/add-sushi.ts --network bsc --project pancake --newFee true",
    "bsc:ape:add": "tsx scripts/add-farm.ts --network bsc --project ape",
    "bsc:biswap:add": "tsx scripts/add-farm.ts --network bsc --project biswap",
    "bsc:thena:add": "tsx scripts/add-solidly.ts --network bsc --project thena --newFee true --lp",
    "bsc:thena:gamma:add": "tsx scripts/add-gamma.ts --network bsc --project thena --lp",
    "bsc:cake:ichi:add": "tsx scripts/add-ichi.ts --network bsc --project pancake --wrapper",
    "bsc:cake:range:add": "tsx scripts/add-ichi.ts --network bsc --project range --wrapper",
    "canto:cvm:add": "tsx scripts/add-solidly.ts --network canto --project cvm --newFee true --lp",
    "fantom:spooky:add": "tsx scripts/add-farm.ts --network fantom --project spooky",
    "fantom:wigo:add": "tsx scripts/add-farm.ts --network fantom --project wigoswap --newFee true --pool",
    "fantom:equalizer:add": "tsx scripts/add-solidly.ts --network fantom --project equalizer --newFee true --lp",
    "fantom:fvm:add": "tsx scripts/add-solidly.ts --network fantom --project fvm --newFee true --lp",
    "fraxtal:ra:add": "tsx scripts/add-solidly.ts --network fraxtal --project ra --newFee true --lp",
    "polygon:quick:add": "tsx scripts/add-quick.ts --network polygon --project quick",
    "polygon:quick:gamma:add": "tsx scripts/add-gamma.ts --network polygon --project quick --wide false --lp",
    "polygon:sushi:add": "tsx scripts/add-sushi.ts --network polygon --project sushiPoly",
    "polygon:retro:add": "tsx scripts/add-gamma.ts --network polygon --project retro --wide true --lp",
    "polygon:retro:ichi:add": "tsx scripts/add-ichi.ts --network polygon --project retro --wrapper",
    "one:sushi:add": "tsx scripts/add-sushi.ts --network one --project sushiOne",
    "arb:sushi:add": "tsx scripts/add-sushi.ts --network arbitrum --project sushiArb --newFee true",
    "arb:uniswap:add": "tsx scripts/add-gamma.ts --network arbitrum --project uniswap --wide true --lp",
    "arb:sushi:gamma:add": "tsx scripts/add-gamma.ts --network arbitrum --project sushi --wide true --lp",
    "celo:sushi:add": "tsx scripts/add-sushi.ts --network celo --project sushiCelo",
    "avax:pangolin:add": "tsx scripts/add-sushi.ts --network avax --project pangolin",
    "avax:boostedjoe:add": "tsx scripts/add-farm.ts --network avax --project boostedjoe",
    "avax:joe:add": "tsx scripts/add-farm.ts --network avax --project joe",
    "aurora:tri:add": "tsx scripts/add-sushi.ts --network aurora --project tri",
    "moonriver:solarbeam:add": "tsx scripts/add-farm.ts --network moonriver --project solarbeam",
    "moonbeam:stella:add": "tsx scripts/add-farm.ts --network moonbeam --project stellaswap --newFee true",
    "linea:lynex:gamma:add": "tsx scripts/add-gamma.ts --network linea --project lynex --wide true --lp",
    "linea:lynex:add": "tsx scripts/add-solidly.ts --network linea --project lynex --newFee true --lp",
    "linea:nile:add": "tsx scripts/add-solidly.ts --network linea --project nile --newFee true --lp",
    "linea:etherex:add": "tsx scripts/add-solidly.ts --network linea --project etherex --newFee true --lp",
    "fuse:fusefi:add": "tsx scripts/add-quick.ts --network fuse --project fusefi",
    "fuse:sushi:add": "tsx scripts/add-sushi.ts --network fuse --project sushiFuse",
    "metis:netswap:add": "tsx scripts/add-farm.ts --network metis --project netswap",
    "metis:tethys:add": "tsx scripts/add-farm.ts --network metis --project tethys",
    "polygon:dystopia:add": "tsx scripts/add-solidly.ts --network polygon --project dystopia --newFee true",
    "polygon:uniswap:add": "tsx scripts/add-univ3.ts --network polygon --project uniswap_polygon --strategy",
    "op:velodrome:add": "tsx scripts/add-solidly.ts --network optimism --project velodrome --newFee true --lp",
    "kava:equilibre:add": "tsx scripts/add-solidly.ts --network kava --project equilibre --newFee true --lp",
    "zksync:velocore:add": "tsx scripts/add-solidly.ts --network zksync --project velocore --newFee true --lp",
    "zksync:vesync:add": "tsx scripts/add-solidly.ts --network zksync --project vesync --newFee true --lp",
    "zksync:dracula:add": "tsx scripts/add-solidly.ts --network zksync --project dracula --newFee true --lp",
    "sonic:equalizer:add": "tsx scripts/add-solidly.ts --network sonic --project sonicEqualizer --newFee true --lp",
    "hyperevm:kittenswap:add": "tsx scripts/add-solidly.ts --network hyperevm --project kittenswap --newFee true --lp",
    "lithos": "tsx scripts/add-solidly.ts --network plasma --project lithos --newFee true --lp",
    "eols": "tsx scripts/findEolPools.js"
  },
  "dependencies": {
    "@apollo/client": "^3.5.6",
    "@biomejs/biome": "2.5.2",
    "@koa/cors": "^3.1.0",
    "@koa/router": "^9.4.0",
    "@types/async-lock": "^1.4.2",
    "async-lock": "^1.4.1",
    "bignumber.js": "^11.1.5",
    "date-fns": "^4.4.0",
    "escape-string-regexp": "^4.0.0",
    "ethers": "^5.7.2",
    "graphql": "^15.5.0",
    "graphql-tag": "^2.12.4",
    "husky": "^9.1.5",
    "jsonpath": "^1.1.1",
    "koa": "^2.13.0",
    "koa-bodyparser": "^4.3.0",
    "koa-conditional-get": "^3.0.0",
    "koa-etag": "^4.0.0",
    "koa-helmet": "^5.2.0",
    "koa-router": "^9.4.0",
    "lodash-es": "^4.18.1",
    "node-cache": "^5.1.2",
    "p-queue": "^9.3.1",
    "pino": "^10.3.1",
    "redis": "^5.8.2",
    "tsx": "^4.23.1",
    "typescript": "~5.3.3",
    "viem": "^1.20.2"
  },
  "devDependencies": {
    "@types/koa": "^2.13.5",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26.1.1",
    "command-line-args": "^5.2.1",
    "fast-glob": "^3.2.12",
    "lint-staged": "^15.2.10",
    "pino-pretty": "^13.1.3",
    "yargs": "^18.0.0"
  },
  "packageManager": "yarn@1.22.22"
}
